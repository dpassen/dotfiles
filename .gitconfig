[user]
  name = Derek Passen
  email = dpassen1@gmail.com

[core]
  excludesfile = ~/.gitignore

[init]
  defaultBranch = main

[pull]
  ff = only

[rerere]
  enabled = true

[diff]
  tool = difftastic

[difftool]
  prompt = false

[difftool "difftastic"]
  cmd = difft "$LOCAL" "$REMOTE"

[pager]
  difftool = true

[alias]
  st = status
  ci = commit
  co = checkout
  ln = log --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset %C(bold blue)<%an>%Creset'
  lg = ln --graph
  ll = ln --decorate --numstat
  scoreboard = shortlog --no-merges -sn
  sb = scoreboard
  standup = !git ln --all --since='yesterday' --author="$(git config user.email)"
  su = standup
  lt = last-touched
  dft = difftool

[github]
  user = dpassen
