   {com.github.liquidz/antq {:mvn/version "0.16.2"}}
   :exec-fn antq.tool/outdated}
  :check
  {:extra-deps
   {com.github.athos/clj-check
    {:git/tag "0.1.0"
     :git/sha "0ca84df"}}
   :main-opts ["-m" "clj-check.check"]}
  :new
  {:extra-deps
   {com.github.seancorfield/clj-new
    {:git/tag "v1.1.324"
     :git/sha "55454b6"}}
   :exec-fn clj-new/create}
  :nop
  {:extra-deps
   {org.slf4j/slf4j-nop {:mvn/version "1.7.32"}}}}}
