{:aliases
 {:antq
  {:deps
   {io.github.liquidz/antq
    {:git/tag "2.9.1232"
     :git/sha "c1d0f9e"}}
   :main-opts ["-m" "antq.core"]}
  :check
  {:extra-deps
   {io.github.athos/clj-check
    {:git/tag "0.1.0"
     :git/sha "0ca84df"}}
   :main-opts ["-m" "clj-check.check"]}
  :new
  {:deps
   {io.github.seancorfield/deps-new
    {:git/tag "v0.8.0"
     :git/sha "2f96530"}}
   :exec-fn org.corfield.new/create}
  :nop
  {:extra-deps
   {org.slf4j/slf4j-nop
    {:mvn/version "2.0.16"}}}
  :splint
  {:deps
   {io.github.noahtheduke/splint
    {:git/tag "v1.17.1"
     :git/sha "dd6e172"}}
   :main-opts ["-m" "noahtheduke.splint"]}
  :watson
  {:deps
   {io.github.clj-holmes/clj-watson
    {:git/tag "v6.0.0"
     :git/sha "cb02879"}}
   :exec-fn clj-watson.entrypoint/scan
   :exec-args
   {:aliases                 ["*"]
    :database-strategy       "dependency-check"
    :deps-edn-path           "deps.edn"
    :fail-on-result          true
    :output                  "stdout"
    :run-without-nvd-api-key true
    :suggest-fix             true}}}}
