{:aliases
 {:antq
  {:extra-deps
   {io.github.liquidz/antq
    {:git/tag "2.9.1217"
     :git/sha "eef233a"}}
   :exec-fn antq.tool/outdated}
  :check
  {:extra-deps
   {io.github.athos/clj-check
    {:git/tag "0.1.0"
     :git/sha "0ca84df"}}
   :main-opts ["-m" "clj-check.check"]}
  :new
  {:extra-deps
   {io.github.seancorfield/deps-new
    {:git/tag "v0.7.1"
     :git/sha "c1e42aa"}}
   :exec-fn org.corfield.new/create}
  :nop
  {:extra-deps
   {org.slf4j/slf4j-nop
    {:mvn/version "2.0.16"}}}
  :splint
  {:extra-deps
   {io.github.noahtheduke/splint
    {:git/tag "v1.16.0"
     :git/sha "ebf06f6"}}
   :main-opts ["-m" "noahtheduke.splint"]}
  :watson
  {:extra-deps
   {io.github.clj-holmes/clj-watson
    {:git/tag "v5.1.3"
     :git/sha "5812615"}}
   :exec-fn clj-watson.entrypoint/scan
   :exec-args
   {:aliases           ["*"]
    :database-strategy "dependency-check"
    :deps-edn-path     "deps.edn"
    :fail-on-result    true
    :output            "stdout"
    :suggest-fix       true}}}}
